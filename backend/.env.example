APP_NAME=Chronicle
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=1

GOOGLE_API_KEY=your_google_api_key_here
KNOWLEDGE_GRAPH_API_KEY=your_knowledge_graph_api_key_here

GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
GEMINI_IMAGE_LOCATION=global
VEO_MODEL=veo-3.1-fast-generate-001

GCS_BUCKET=your-gcs-bucket-name
FIRESTORE_COLLECTION=your_firestore_collection
FIRESTORE_REQUIRED=true
ADK_SESSION_SERVICE=memory

IMAGE_GENERATION_CONCURRENCY=2
IMAGE_REQUEST_SPACING_SECONDS=1.5

PORT=8080
